# Copy to .env.local and fill with your Supabase project values.
# Vite only exposes vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Absolute session lifetime in hours. After this many hours since sign-in the
# user is forced to re-authenticate. Optional — defaults to 24 when unset.
VITE_SESSION_MAX_HOURS=24
