# Copy to .env.local and fill with your Supabase project values.
# Vite only exposes vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Absolute session lifetime in hours when "Keep me signed in" is UNCHECKED
# (the default). After this many hours since sign-in the user must re-auth.
# Optional — defaults to 24 when unset.
VITE_SESSION_MAX_HOURS=24

# Absolute session lifetime in DAYS when "Keep me signed in" is CHECKED.
# Optional — defaults to 30 (1 month) when unset.
VITE_SESSION_REMEMBER_DAYS=30

# --- booking-confirm Edge Function (server-side secrets, NOT in the browser) --
# These are set as Supabase function secrets, NOT in .env.local:
#   supabase secrets set RESEND_API_KEY=re_xxx \
#     EMAIL_FROM="Guapito's Barbershop <noreply@yourdomain.com>" \
#     APP_URL=https://your-deployed-site.com
# RESEND_API_KEY — Resend API key used to send the confirmation email.
# EMAIL_FROM     — verified sender address (Resend-verified domain).
# APP_URL        — public site URL the email's Reschedule/Cancel links point to.
